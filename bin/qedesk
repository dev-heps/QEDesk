#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
COMPOSE=(docker compose --project-directory "$PROJECT_DIR")
SERVICE=qedesk
PDF_BUILD_DIR=build

is_worksheet() {
  local target="${1:-}"
  [ -n "$target" ] \
    && [ -d "$PROJECT_DIR/$target" ] \
    && [ -f "$PROJECT_DIR/$target/main.tex" ] \
    && [ -f "$PROJECT_DIR/$target/Proof.lean" ]
}

shell_quote() {
  printf "%q" "$1"
}

is_running() {
  "${COMPOSE[@]}" ps --status running --services 2>/dev/null | grep -qx "$SERVICE"
}

require_running() {
  if ! is_running; then
    echo "QEDesk is not running. Start it first:" >&2
    echo >&2
    echo "  ./bin/qedesk start" >&2
    exit 1
  fi
}

usage() {
  cat <<'EOF'
QEDesk command line

Usage:
  qedesk <command>

Commands:
  start         Build and start the QEDesk container
  stop          Stop and remove the container
  restart       Restart the container
  status        Show container status
  shell         Open a shell inside the container
  files         Show the main files to edit
  storage       Show project and Docker storage use
  new           Create a worksheet under worksheets/<slug>
  list          List worksheet directories
  info          Show worksheet paths
  contracts     Show QEDesk v0.2 data-contract files
  sync          Sync Lean declarations into TeX, blueprint, and DAG files
  blueprint     Build the Lean Blueprint HTML visualization
  serve         Serve the generated Blueprint and dependency graph
  prepare       Build Lean once before launching MCP/OpenCode
  cache         Fetch Mathlib/Lean dependency cache when available
  lean          Build the Lean library
  build-lean    Alias for lean
  pdf           Build build/main.pdf from src/main.tex
  agent         Run lean-lsp-mcp inside the container
  audit         Audit QEDesk nodes through the OpenRouter router
  formalize     Ask the router for local Lean statements or skeletons
  repair        Ask the router for a local repair hint from a Lean error
  route         Show the model tier selected for a node
  cost          Show the OpenRouter cost ledger summary
  init-ledger   Create the local cost ledger database
  clean         Remove local build artifacts
  cost-reset    Remove the local OpenRouter cost ledger
  docker-clean  Remove the local QEDesk container and image
  help          Show this help
EOF
}

command="${1:-help}"
shift || true

case "$command" in
  start)
    "${COMPOSE[@]}" up -d "$@"
    ;;
  stop)
    "${COMPOSE[@]}" down "$@"
    ;;
  restart)
    "${COMPOSE[@]}" down
    "${COMPOSE[@]}" up -d "$@"
    ;;
  status)
    "${COMPOSE[@]}" ps "$@"
    ;;
  shell)
    require_running
    "${COMPOSE[@]}" exec "$SERVICE" bash "$@"
    ;;
  files)
    cat <<EOF
Edit these files in your editor:

  Lean source:   $PROJECT_DIR/src/Proof.lean
  LaTeX notes:   $PROJECT_DIR/src/main.tex
  Architecture:  $PROJECT_DIR/docs/ARCHITECTURE.md
  Data contract: $PROJECT_DIR/docs/DATA_CONTRACTS.md
  PDF output:    $PROJECT_DIR/$PDF_BUILD_DIR/main.pdf

Do not run src/Proof.lean or src/main.tex as shell commands.
Use:

  ./bin/qedesk lean
  ./bin/qedesk pdf
EOF
    ;;
  storage)
    echo "Project generated files:"
    (
      cd "$PROJECT_DIR"
      du -sh .lake build blueprint outputs worksheets 2>/dev/null || true
    )
    echo
    echo "Docker storage:"
    docker system df -v
    ;;
  contracts)
    cat <<EOF
QEDesk v0.2 data contracts:

  Architecture:       $PROJECT_DIR/docs/ARCHITECTURE.md
  Data contracts:     $PROJECT_DIR/docs/DATA_CONTRACTS.md
  Integrations:       $PROJECT_DIR/docs/INTEGRATIONS.md
  Agent rules:        $PROJECT_DIR/AGENTS.md
  OpenCode config:    $PROJECT_DIR/opencode.json
  Router config:      $PROJECT_DIR/qedesk-router.json
  DAG schema:         $PROJECT_DIR/schemas/qedesk-dag.schema.json
  Blueprint source:   $PROJECT_DIR/blueprint/src/content.tex
  Blueprint HTML:     $PROJECT_DIR/blueprint/web/index.html
  DAG output:         $PROJECT_DIR/build/qedesk-dag.json
  Mermaid DAG:        $PROJECT_DIR/build/qedesk-dag.mmd
  Cost ledger:        $PROJECT_DIR/build/qedesk-ledger.sqlite

src/main.tex remains the student-facing source of truth.
qedesk sync regenerates Blueprint source and the DAG sidecar from src/Proof.lean.
EOF
    ;;
  sync)
    require_running
    "${COMPOSE[@]}" exec -T "$SERVICE" python tools/qedesk_sync.py "$@"
    ;;
  blueprint)
    require_running
    if is_worksheet "${1:-}"; then
      worksheet="$1"
      worksheet_q="$(shell_quote "$worksheet")"
      "${COMPOSE[@]}" exec -T "$SERVICE" python tools/qedesk_sync.py "$worksheet"
      "${COMPOSE[@]}" exec -T "$SERVICE" sh -lc "cd $worksheet_q && leanblueprint web"
      "${COMPOSE[@]}" exec -T "$SERVICE" python tools/qedesk_blueprint_ui.py "$worksheet/blueprint/web"
      echo
      echo "Blueprint HTML written to: $PROJECT_DIR/$worksheet/blueprint/web/index.html"
      echo "Dependency graph written to: $PROJECT_DIR/$worksheet/blueprint/web/dep_graph_document.html"
      echo
      echo "To view it through the upstream Lean Blueprint server:"
      echo "  ./bin/qedesk serve $worksheet"
      exit 0
    fi
    "${COMPOSE[@]}" exec -T "$SERVICE" python tools/qedesk_sync.py
    "${COMPOSE[@]}" exec -T "$SERVICE" leanblueprint web "$@"
    "${COMPOSE[@]}" exec -T "$SERVICE" python tools/qedesk_blueprint_ui.py
    echo
    echo "Blueprint HTML written to: $PROJECT_DIR/blueprint/web/index.html"
    echo "Dependency graph written to: $PROJECT_DIR/blueprint/web/dep_graph_document.html"
    echo
    echo "To view it through the upstream Lean Blueprint server:"
    echo "  ./bin/qedesk serve"
    ;;
  serve)
    require_running
    if is_worksheet "${1:-}"; then
      worksheet="$1"
      worksheet_q="$(shell_quote "$worksheet")"
      if [ ! -f "$PROJECT_DIR/$worksheet/blueprint/web/index.html" ] || [ ! -f "$PROJECT_DIR/$worksheet/blueprint/web/dep_graph_document.html" ]; then
        "${COMPOSE[@]}" exec -T "$SERVICE" python tools/qedesk_sync.py "$worksheet"
        "${COMPOSE[@]}" exec -T "$SERVICE" sh -lc "cd $worksheet_q && leanblueprint web"
        "${COMPOSE[@]}" exec -T "$SERVICE" python tools/qedesk_blueprint_ui.py "$worksheet/blueprint/web"
      fi
      echo "Serving Blueprint at http://localhost:8000/"
      echo "Dependency graph: http://localhost:8000/dep_graph_document.html"
      "${COMPOSE[@]}" exec "$SERVICE" sh -lc "cd $worksheet_q && leanblueprint serve"
      exit 0
    fi
    if [ ! -f "$PROJECT_DIR/blueprint/web/index.html" ] || [ ! -f "$PROJECT_DIR/blueprint/web/dep_graph_document.html" ]; then
      "${COMPOSE[@]}" exec -T "$SERVICE" python tools/qedesk_sync.py
      "${COMPOSE[@]}" exec -T "$SERVICE" leanblueprint web
      "${COMPOSE[@]}" exec -T "$SERVICE" python tools/qedesk_blueprint_ui.py
    fi
    echo "Serving Blueprint at http://localhost:8000/"
    echo "Dependency graph: http://localhost:8000/dep_graph_document.html"
    "${COMPOSE[@]}" exec "$SERVICE" leanblueprint serve "$@"
    ;;
  prepare)
    require_running
    "${COMPOSE[@]}" exec "$SERVICE" lake build Proof "$@"
    ;;
  cache)
    require_running
    "${COMPOSE[@]}" exec "$SERVICE" lake exe cache get "$@"
    ;;
  lean|build-lean)
    require_running
    if is_worksheet "${1:-}"; then
      worksheet="$1"
      shift
      "${COMPOSE[@]}" exec "$SERVICE" lake env lean "$worksheet/Proof.lean" "$@"
    else
      "${COMPOSE[@]}" exec "$SERVICE" lake build Proof "$@"
    fi
    ;;
  pdf)
    require_running
    if is_worksheet "${1:-}"; then
      worksheet="$1"
      shift
      worksheet_q="$(shell_quote "$worksheet")"
      if ! "${COMPOSE[@]}" exec "$SERVICE" sh -lc "cd $worksheet_q && mkdir -p build && latexmk -pdf -g -shell-escape -interaction=nonstopmode -halt-on-error -output-directory=build main.tex" "$@"; then
        echo
        echo "PDF build failed. Check $worksheet/build/main.log."
        exit 1
      fi
      exit 0
    fi
    mkdir -p "$PROJECT_DIR/$PDF_BUILD_DIR"
    if ! "${COMPOSE[@]}" exec "$SERVICE" latexmk -pdf -g -shell-escape -interaction=nonstopmode -halt-on-error -output-directory="$PDF_BUILD_DIR" src/main.tex "$@"; then
      echo
      echo "Could not write build/main.pdf. If it is open in a PDF viewer, close it and retry."
      echo "Trying build/main-preview.pdf instead..."
      if "${COMPOSE[@]}" exec "$SERVICE" latexmk -pdf -g -jobname=main-preview -shell-escape -interaction=nonstopmode -halt-on-error -output-directory="$PDF_BUILD_DIR" src/main.tex "$@"; then
        echo
        echo "PDF written to build/main-preview.pdf"
      else
        echo
        echo "PDF build failed. Check src/main.tex and build/main-preview.log."
        exit 1
      fi
    fi
    ;;
  agent)
    require_running
    if [ -t 0 ]; then
      cat >&2 <<'EOF'
qedesk agent starts the Lean MCP stdio server.

It is meant to be launched by an MCP client, not used as an interactive shell.
If you want a terminal inside the container, run:

  ./bin/qedesk shell

If you started the agent by accident, you are still in a normal shell now.
EOF
      exit 2
    fi
    "${COMPOSE[@]}" exec -T "$SERVICE" lean-lsp-mcp "$@"
    ;;
  audit|formalize|repair|route|cost|init-ledger)
    require_running
    "${COMPOSE[@]}" exec -T "$SERVICE" python tools/qedesk_router.py "$command" "$@"
    ;;
  new)
    python3 "$PROJECT_DIR/tools/qedesk_worksheet.py" new "$@"
    ;;
  list)
    python3 "$PROJECT_DIR/tools/qedesk_worksheet.py" list "$@"
    ;;
  info)
    python3 "$PROJECT_DIR/tools/qedesk_worksheet.py" info "$@"
    ;;
  clean)
    if ! (
      cd "$PROJECT_DIR"
      "${COMPOSE[@]}" exec -T "$SERVICE" sh -lc 'find build -mindepth 1 ! -name qedesk-ledger.sqlite -delete 2>/dev/null || true; rm -rf _minted-* *.aux *.fdb_latexmk *.fls *.log *.out *.pdf blueprint/web blueprint/lean_decls blueprint/src/*.paux' 2>/dev/null \
        || (
          mkdir -p "$PDF_BUILD_DIR"
          find "$PDF_BUILD_DIR" -mindepth 1 ! -name qedesk-ledger.sqlite -delete 2>/dev/null || true
          rm -rf -- _minted-* *.aux *.fdb_latexmk *.fls *.log *.out *.pdf blueprint/web blueprint/lean_decls blueprint/src/*.paux
        )
      find worksheets -type d \( -path '*/build' -o -path '*/blueprint/web' -o -path '*/blueprint/lean_decls' \) -prune -exec rm -rf {} + 2>/dev/null || true
      find worksheets -path '*/blueprint/src/*.paux' -delete 2>/dev/null || true
    ); then
      echo "Some generated files are locked. Close PDF viewers and retry qedesk clean."
      exit 0
    fi
    ;;
  cost-reset)
    rm -f "$PROJECT_DIR/$PDF_BUILD_DIR/qedesk-ledger.sqlite"
    ;;
  docker-clean)
    "${COMPOSE[@]}" down --remove-orphans --volumes
    docker image rm -f qedesk || true
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    echo "Unknown command: $command" >&2
    echo >&2
    usage >&2
    exit 2
    ;;
esac
